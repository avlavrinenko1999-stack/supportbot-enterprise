[Unit]
Description=SupportBot Enterprise web interface
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/supportbot_v2
Environment=WEB_HOST=0.0.0.0
Environment=WEB_PORT=8080
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/opt/supportbot_v2/venv/bin/python -m web.server
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
